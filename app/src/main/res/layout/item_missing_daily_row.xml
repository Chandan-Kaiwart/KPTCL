<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="4dp"
    app:cardCornerRadius="8dp"
    app:cardElevation="2dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical">
                <TextView android:id="@+id/tvFeederName"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:textStyle="bold" android:textSize="14sp" android:textColor="#333" />
                <TextView android:id="@+id/tvCategory"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:textSize="11sp" android:textColor="#888" />
            </LinearLayout>

            <TextView android:id="@+id/tvStatus"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:textSize="12sp" android:textStyle="bold" android:gravity="end"
                android:layout_gravity="center_vertical" />
        </LinearLayout>

        <!-- Input fields -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:paddingTop="8dp">

            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical" android:paddingEnd="4dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Total (MU)" android:textSize="10sp" android:textColor="#666" />
                <EditText android:id="@+id/etTotalConsumption"
                    android:layout_width="match_parent" android:layout_height="40dp"
                    android:inputType="numberDecimal" android:hint="0.0"
                    android:textSize="13sp" android:padding="4dp"
                    android:background="@drawable/edit_text_border" />
            </LinearLayout>

            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical" android:paddingEnd="4dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="3PH (HH:MM)" android:textSize="10sp" android:textColor="#666" />
                <EditText android:id="@+id/etSupply3ph"
                    android:layout_width="match_parent" android:layout_height="40dp"
                    android:inputType="text" android:hint="18:30"
                    android:textSize="13sp" android:padding="4dp"
                    android:background="@drawable/edit_text_border" />
            </LinearLayout>

            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="1PH (HH:MM)" android:textSize="10sp" android:textColor="#666" />
                <EditText android:id="@+id/etSupply1ph"
                    android:layout_width="match_parent" android:layout_height="40dp"
                    android:inputType="text" android:hint="05:30"
                    android:textSize="13sp" android:padding="4dp"
                    android:background="@drawable/edit_text_border" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:paddingTop="6dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Remark" android:textSize="10sp" android:textColor="#666" />
            <EditText android:id="@+id/etRemark"
                android:layout_width="match_parent" android:layout_height="40dp"
                android:inputType="text" android:hint="PROPER"
                android:textSize="13sp" android:padding="4dp"
                android:background="@drawable/edit_text_border" />
        </LinearLayout>
    </LinearLayout>
</androidx.cardview.widget.CardView>