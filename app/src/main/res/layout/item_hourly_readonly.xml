<?xml version="1.0" encoding="utf-8"?>
<!-- FILE: res/layout/item_hourly_readonly.xml -->
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="7dp"
    app:cardBackgroundColor="#FFFFFF"
    app:cardCornerRadius="10dp"
    app:cardElevation="0dp"
    app:strokeColor="#E0E0E0"
    app:strokeWidth="1dp">

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="vertical" android:padding="12dp">

        <TextView android:id="@+id/tvFeederName"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="—" android:textColor="#1A56A0"
            android:textSize="13sp" android:textStyle="bold" android:layout_marginBottom="6dp" />

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:layout_marginBottom="4dp">
            <TextView android:layout_width="70dp" android:layout_height="wrap_content"
                android:text="Code" android:textColor="#999999" android:textSize="11sp" />
            <TextView android:id="@+id/tvFeederCode" android:layout_width="0dp"
                android:layout_height="wrap_content" android:layout_weight="1"
                android:text="—" android:textColor="#444444" android:textSize="11sp" />
            <TextView android:id="@+id/tvFeederCategory"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="—" android:textSize="10sp" android:textColor="#00695C"
                android:textStyle="bold" android:background="@drawable/category_badge_bg"
                android:paddingStart="8dp" android:paddingEnd="8dp"
                android:paddingTop="2dp" android:paddingBottom="2dp" />
        </LinearLayout>

        <View android:layout_width="match_parent" android:layout_height="0.5dp"
            android:background="#EEEEEE" android:layout_marginTop="4dp"
            android:layout_marginBottom="6dp" />

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal">
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Peak Load" android:textColor="#999999" android:textSize="10sp" />
                <TextView android:id="@+id/tvPeakLoad"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="— MW" android:textColor="#E65100"
                    android:textSize="14sp" android:textStyle="bold" />
            </LinearLayout>
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical" android:gravity="end">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Peak Hour" android:textColor="#999999" android:textSize="10sp" />
                <TextView android:id="@+id/tvPeakHour"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="—" android:textColor="#6A1B9A"
                    android:textSize="14sp" android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>