<?xml version="1.0" encoding="utf-8"?>
<!-- FILE: res/layout/fragment_division_ticket_view.xml -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F0F2F5">

    <!-- TOP BAR -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="#6A1B9A"
        android:padding="12dp">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_arrow_back"
            app:tint="#FFFFFF"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Back"
            android:layout_marginEnd="10dp" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Ticket List"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:textStyle="bold" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="View only — no actions permitted"
                android:textColor="#CE93D8"
                android:textSize="10sp" />
        </LinearLayout>

        <TextView
            android:id="@+id/tvTicketCount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="#CE93D8"
            android:textSize="11sp" />
    </LinearLayout>

    <!-- VIEW ONLY BANNER -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="#E8F5E9"
        android:paddingStart="14dp"
        android:paddingEnd="14dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp">
        <View
            android:layout_width="6dp"
            android:layout_height="6dp"
            android:background="@drawable/circle_green"
            android:layout_marginEnd="8dp" />
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Division view — approve/reject actions are disabled"
            android:textColor="#1B5E20"
            android:textSize="11sp"
            android:textStyle="italic" />
    </LinearLayout>

    <!-- CHIP FILTER ROW -->
    <com.google.android.material.chip.ChipGroup
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="10dp"
        android:paddingEnd="10dp"
        android:paddingTop="8dp"
        android:paddingBottom="4dp"
        app:singleSelection="true"
        app:selectionRequired="true">

        <com.google.android.material.chip.Chip
            android:id="@+id/chipAll"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="All"
            android:checked="true"
            style="@style/Widget.MaterialComponents.Chip.Filter" />

        <com.google.android.material.chip.Chip
            android:id="@+id/chipActive"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Active"
            style="@style/Widget.MaterialComponents.Chip.Filter" />

        <com.google.android.material.chip.Chip
            android:id="@+id/chipApproved"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Approved"
            style="@style/Widget.MaterialComponents.Chip.Filter" />

        <com.google.android.material.chip.Chip
            android:id="@+id/chipRejected"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Rejected"
            style="@style/Widget.MaterialComponents.Chip.Filter" />

    </com.google.android.material.chip.ChipGroup>

    <!-- ── DATE RANGE FILTER CARD ─────────────────────────────── -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="10dp"
        android:layout_marginEnd="10dp"
        android:layout_marginTop="6dp"
        android:layout_marginBottom="4dp"
        app:cardCornerRadius="10dp"
        app:cardElevation="2dp"
        app:cardBackgroundColor="#FFFFFF">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="10dp">

            <!-- Collapsed header row — tap to expand/collapse -->
            <LinearLayout
                android:id="@+id/llDateFilterHeader"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="?attr/selectableItemBackground"
                android:padding="2dp">

                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/ic_calendar"
                    app:tint="#6A1B9A"
                    android:layout_marginEnd="6dp"
                    android:contentDescription="Calendar" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Date Range Filter"
                    android:textColor="#6A1B9A"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <!-- Active range label — shows when filter is applied -->
                <TextView
                    android:id="@+id/tvActiveDateRange"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textColor="#6A1B9A"
                    android:textSize="10sp"
                    android:maxLines="1"
                    android:ellipsize="end"
                    android:layout_marginEnd="4dp"
                    android:visibility="gone" />

                <ImageView
                    android:id="@+id/ivDateFilterArrow"
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:src="@drawable/ic_arrow_drop_down"
                    app:tint="#6A1B9A"
                    android:contentDescription="Expand" />

            </LinearLayout>

            <!-- Expandable body -->
            <LinearLayout
                android:id="@+id/llDateFilterBody"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <!-- Divider -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#E0E0E0"
                    android:layout_marginTop="8dp"
                    android:layout_marginBottom="8dp" />

                <!-- From / To date pickers in a horizontal row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <!-- FROM DATE -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginEnd="6dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="From"
                            android:textColor="#666666"
                            android:textSize="10sp"
                            android:layout_marginBottom="3dp" />

                        <LinearLayout
                            android:id="@+id/llFromDate"
                            android:layout_width="match_parent"
                            android:layout_height="38dp"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:background="@drawable/bg_date_picker_field"
                            android:paddingStart="10dp"
                            android:paddingEnd="6dp"
                            >

                            <TextView
                                android:id="@+id/tvFromDate"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Select date"
                                android:textColor="#9E9E9E"
                                android:textSize="12sp" />

                            <ImageView
                                android:layout_width="16dp"
                                android:layout_height="16dp"
                                android:src="@drawable/ic_calendar"
                                app:tint="#9E9E9E"
                                android:contentDescription="Pick from date" />
                        </LinearLayout>
                    </LinearLayout>

                    <!-- Arrow between dates -->
                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:src="@drawable/ic_arrow_forward"
                        app:tint="#AAAAAA"
                        android:layout_marginEnd="6dp"
                        android:contentDescription="to" />

                    <!-- TO DATE -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="To"
                            android:textColor="#666666"
                            android:textSize="10sp"
                            android:layout_marginBottom="3dp" />

                        <LinearLayout
                            android:id="@+id/llToDate"
                            android:layout_width="match_parent"
                            android:layout_height="38dp"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:paddingStart="10dp"
                            android:paddingEnd="6dp"
                            android:background="#F5F5F5">

                            <TextView
                                android:id="@+id/tvToDate"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Select date"
                                android:textColor="#9E9E9E"
                                android:textSize="12sp" />

                            <ImageView
                                android:layout_width="16dp"
                                android:layout_height="16dp"
                                android:src="@drawable/ic_calendar"
                                app:tint="#9E9E9E"
                                android:contentDescription="Pick to date" />
                        </LinearLayout>
                    </LinearLayout>

                </LinearLayout>

                <!-- Action buttons row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="end"
                    android:layout_marginTop="10dp">

                    <Button
                        android:id="@+id/btnClearDateFilter"
                        android:layout_width="wrap_content"
                        android:layout_height="32dp"
                        android:text="Clear"
                        android:textSize="12sp"
                        android:textColor="#6A1B9A"
                        android:backgroundTint="@android:color/transparent"
                        style="@style/Widget.MaterialComponents.Button.TextButton"
                        android:layout_marginEnd="6dp" />

                    <Button
                        android:id="@+id/btnApplyDateFilter"
                        android:layout_width="wrap_content"
                        android:layout_height="32dp"
                        android:text="Apply"
                        android:textSize="12sp"
                        android:textColor="#FFFFFF"
                        android:backgroundTint="#6A1B9A"
                        style="@style/Widget.MaterialComponents.Button" />

                </LinearLayout>
            </LinearLayout>

        </LinearLayout>
    </androidx.cardview.widget.CardView>
    <!-- ── END DATE RANGE FILTER ───────────────────────────────── -->

    <!-- LOADING -->
    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="32dp"
        android:visibility="gone" />

    <!-- EMPTY -->
    <TextView
        android:id="@+id/tvEmpty"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="No tickets found"
        android:textColor="#999999"
        android:textSize="14sp"
        android:gravity="center"
        android:paddingTop="48dp"
        android:visibility="gone" />

    <!-- TICKET LIST -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvTickets"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="10dp"
        android:clipToPadding="false"
        android:visibility="gone" />

</LinearLayout>