<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="8dp"
    app:cardCornerRadius="8dp"
    android:background="@drawable/bg_card"
    app:cardElevation="4dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/bg_card"
        android:padding="16dp">

        <!-- Ticket ID -->
        <TextView
            android:id="@+id/tvTicketId"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="KPTCL_elog_xxx"
            android:textSize="12sp"
            android:textColor="@color/text_secondary"
            android:textStyle="bold" />

        <!-- Station -->
        <TextView
            android:id="@+id/tvStation"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Station: GALAG_110"
            android:textSize="14sp"
            android:textColor="@color/text_primary"
            android:textStyle="bold" />

        <!-- Classification Badge -->
        <TextView
            android:id="@+id/tvClassification"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:background="@drawable/badge_classification"
            android:padding="8dp"
            android:text="NEW FEEDER ADDITION"
            android:textSize="12sp"
            android:textColor="@android:color/white"
            android:textStyle="bold" />

        <!-- Problem Statement -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Problem:"
            android:textSize="12sp"
            android:textColor="@color/text_secondary"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvProblemStatement"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Feeder needs to be added"
            android:textSize="14sp"
            android:textColor="@color/text_primary" />

        <!-- Classification Details -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Details:"
            android:textSize="12sp"
            android:textColor="@color/text_secondary"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvDetails"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:background="@drawable/bg_details"
            android:padding="12dp"
            android:text="NEW_FEEDER_NAME: F-7 Wachnayakathanda\nNEW_FEEDER_CATEGORY: IP"
            android:textSize="13sp"
            android:textColor="@color/text_primary"
            android:fontFamily="monospace" />

        <!-- ✅ DCC Feeder Code Input (shown only for FEEDER CODE and NEW FEEDER ADDITION) -->
        <TextView
            android:id="@+id/tvFeederCodeNote"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="⚠️ DCC: Enter new feeder code"
            android:textSize="12sp"
            android:textColor="@color/warning_orange"
            android:textStyle="bold"
            android:visibility="gone" />

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilNewFeederCode"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:visibility="gone"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            app:boxStrokeColor="@color/primary_dark"
            app:hintTextColor="@color/primary_dark">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etNewFeederCode"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Enter new feeder code"
                android:inputType="textCapCharacters"
                android:textSize="14sp" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Date Time -->
        <TextView
            android:id="@+id/tvDateTime"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="2026-01-14 12:27:00"
            android:textSize="12sp"
            android:textColor="@color/text_secondary" />

        <!-- Action Buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:orientation="horizontal"
            android:gravity="end">

            <!-- Reject Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnReject"
                android:layout_width="wrap_content"
                android:layout_height="48dp"
                android:text="❌ REJECT"
                android:textColor="@android:color/white"
                app:backgroundTint="@color/red_500"
                app:cornerRadius="8dp"
                style="@style/Widget.MaterialComponents.Button" />

            <!-- Approve Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnApprove"
                android:layout_width="wrap_content"
                android:layout_height="48dp"
                android:layout_marginStart="12dp"
                android:text="✅ APPROVE"
                android:textColor="@android:color/white"
                app:backgroundTint="@color/green_500"
                app:cornerRadius="8dp"
                style="@style/Widget.MaterialComponents.Button" />
        </LinearLayout>
    </LinearLayout>

</com.google.android.material.card.MaterialCardView>