<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:padding="2dp"
    android:gravity="center_vertical">

    <TextView
        android:id="@+id/tvHour"
        android:layout_width="40dp"
        android:layout_height="wrap_content"
        android:textSize="11sp"
        android:textStyle="bold"
        android:gravity="center"
        android:textColor="#333" />

    <EditText android:id="@+id/etIR"
        android:layout_width="0dp" android:layout_height="36dp" android:layout_weight="1"
        android:textSize="11sp" android:padding="4dp" android:gravity="center"
        android:imeOptions="actionNext" android:singleLine="true" android:inputType="number"
        android:background="@drawable/edit_text_border" android:layout_margin="1dp" />


    <EditText android:id="@+id/etIB"
        android:layout_width="0dp" android:layout_height="36dp" android:layout_weight="1"
        android:textSize="11sp" android:padding="4dp" android:gravity="center"
        android:imeOptions="actionNext" android:singleLine="true" android:inputType="number"
        android:background="@drawable/edit_text_border" android:layout_margin="1dp" />


    <EditText android:id="@+id/etIY"
        android:layout_width="0dp" android:layout_height="36dp" android:layout_weight="1"
        android:textSize="11sp" android:padding="4dp" android:gravity="center"
        android:imeOptions="actionNext" android:singleLine="true" android:inputType="number"
        android:background="@drawable/edit_text_border" android:layout_margin="1dp" />

    <EditText android:id="@+id/etMW"
        android:layout_width="0dp" android:layout_height="36dp" android:layout_weight="1"
        android:textSize="11sp" android:padding="4dp" android:gravity="center"
        android:imeOptions="actionNext" android:singleLine="true"
        android:inputType="numberDecimal"
        android:background="@drawable/edit_text_border" android:layout_margin="1dp" />

    <EditText android:id="@+id/etMVAR"
        android:layout_width="0dp" android:layout_height="36dp" android:layout_weight="1"
        android:textSize="11sp" android:padding="4dp" android:gravity="center"
        android:imeOptions="actionDone" android:singleLine="true"
        android:inputType="numberDecimal|numberSigned"
        android:background="@drawable/edit_text_border" android:layout_margin="1dp" />
</LinearLayout>