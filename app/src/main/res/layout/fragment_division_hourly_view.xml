<?xml version="1.0" encoding="utf-8"?>
<!-- FILE: res/layout/fragment_division_hourly_view.xml -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F0F2F5">

    <!-- TOP BAR -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="#00838F"
        android:padding="12dp">
        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="36dp" android:layout_height="36dp"
            android:src="@drawable/ic_arrow_back"
            app:tint="#FFFFFF"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Back"
            android:layout_marginEnd="10dp" />
        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:orientation="vertical">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Hourly View" android:textColor="#FFFFFF"
                android:textSize="15sp" android:textStyle="bold" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="IB · IR · IY · MW · MVAR — View only"
                android:textColor="#B2EBF2" android:textSize="10sp" />
        </LinearLayout>
        <TextView android:id="@+id/tvRowCount" android:layout_width="wrap_content"
            android:layout_height="wrap_content" android:text=""
            android:textColor="#B2EBF2" android:textSize="11sp" />
    </LinearLayout>

    <!-- FILTER CARD -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:layout_margin="10dp"
        app:cardBackgroundColor="#FFFFFF" app:cardCornerRadius="10dp"
        app:cardElevation="0dp" app:strokeColor="#E0E0E0" app:strokeWidth="1dp">
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:padding="12dp">

            <!-- Date row -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center_vertical"
                android:layout_marginBottom="8dp">
                <TextView android:layout_width="70dp" android:layout_height="wrap_content"
                    android:text="Date" android:textColor="#666666" android:textSize="12sp" />
                <TextView android:id="@+id/tvSelectedDate" android:layout_width="0dp"
                    android:layout_height="wrap_content" android:layout_weight="1"
                    android:text="—" android:textColor="#1A56A0"
                    android:textSize="13sp" android:textStyle="bold" />
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnPickDate"
                    android:layout_width="wrap_content" android:layout_height="34dp"
                    android:text="Change" android:textSize="11sp"
                    app:backgroundTint="#E3F2FD" android:textColor="#1565C0"
                    app:cornerRadius="6dp"
                    style="@style/Widget.MaterialComponents.Button.TextButton" />
            </LinearLayout>

            <!-- Station row -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center_vertical"
                android:layout_marginBottom="8dp">
                <TextView android:layout_width="70dp" android:layout_height="wrap_content"
                    android:text="Station" android:textColor="#666666" android:textSize="12sp" />
                <Spinner
                    android:id="@+id/spinnerStation"
                    android:layout_width="0dp" android:layout_height="38dp"
                    android:layout_weight="1"
                    android:background="@drawable/input_bg"
                    android:visibility="gone" />
                <EditText
                    android:id="@+id/etStation"
                    android:layout_width="0dp" android:layout_height="38dp"
                    android:layout_weight="1"
                    android:hint="Station name" android:textSize="12sp"
                    android:textColor="#333333" android:background="@drawable/input_bg"
                    android:paddingStart="10dp" android:paddingEnd="10dp"
                    android:inputType="textCapCharacters" android:imeOptions="actionDone" />
            </LinearLayout>

            <!-- Parameter row -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center_vertical"
                android:layout_marginBottom="12dp">
                <TextView android:layout_width="70dp" android:layout_height="wrap_content"
                    android:text="Parameter" android:textColor="#666666" android:textSize="12sp" />
                <Spinner android:id="@+id/spinnerParameter"
                    android:layout_width="0dp" android:layout_height="38dp"
                    android:layout_weight="1" android:background="@drawable/input_bg" />
            </LinearLayout>

            <!-- Button row: Search + Download Excel -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal">
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnSearch"
                    android:layout_width="0dp" android:layout_height="44dp"
                    android:layout_weight="1" android:layout_marginEnd="6dp"
                    android:text="Search" android:textColor="#FFFFFF"
                    android:textStyle="bold" android:textSize="13sp"
                    app:backgroundTint="#00838F" app:cornerRadius="8dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnDownloadExcel"
                    android:layout_width="wrap_content" android:layout_height="44dp"
                    android:text="Excel" android:textColor="#FFFFFF"
                    android:textStyle="bold" android:textSize="12sp"
                    app:backgroundTint="#1B5E20" app:cornerRadius="8dp"
                    android:visibility="gone" />
            </LinearLayout>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- RESULT TITLE -->
    <TextView android:id="@+id/tvResultTitle" android:layout_width="match_parent"
        android:layout_height="wrap_content" android:text="" android:textColor="#1A56A0"
        android:textSize="12sp" android:textStyle="bold" android:gravity="center"
        android:paddingStart="12dp" android:paddingEnd="12dp" android:paddingBottom="4dp"
        android:visibility="gone" />

    <!-- Row count subtitle -->
    <TextView android:id="@+id/tvRowSubtitle" android:layout_width="match_parent"
        android:layout_height="wrap_content" android:text=""
        android:textColor="#888888" android:textSize="10sp" android:gravity="center"
        android:paddingBottom="6dp" android:visibility="gone" />

    <!-- LOADING -->
    <ProgressBar android:id="@+id/progressBar" android:layout_width="wrap_content"
        android:layout_height="wrap_content" android:layout_gravity="center_horizontal"
        android:visibility="gone" />

    <!-- EMPTY -->
    <TextView android:id="@+id/tvEmpty" android:layout_width="match_parent"
        android:layout_height="wrap_content" android:text="No data found for selected filters"
        android:textColor="#999999" android:textSize="13sp" android:gravity="center"
        android:padding="24dp" android:visibility="gone" />
    <HorizontalScrollView
        android:id="@+id/scrollHourFilter"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scrollbars="none"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:paddingBottom="6dp"
        android:visibility="gone">
        <LinearLayout
            android:id="@+id/chipGroup"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical" />
    </HorizontalScrollView>
    <!-- PORTAL-STYLE TABLE: outer vertical scroll, inner horizontal scroll -->
    <ScrollView
        android:id="@+id/scrollVertical"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:visibility="gone"
        android:fillViewport="false">

        <HorizontalScrollView
            android:id="@+id/scrollHorizontal"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fillViewport="false">

            <!-- Table container: header row + data rows added programmatically -->
            <LinearLayout
                android:id="@+id/tableContainer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="8dp" />

        </HorizontalScrollView>
    </ScrollView>

</LinearLayout>