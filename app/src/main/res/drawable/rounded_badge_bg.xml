<?xml version="1.0" encoding="utf-8"?>
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">

    <!-- Background color -->
    <solid android:color="#F1F3F4"/> <!-- Light neutral -->

    <!-- Fully rounded (pill shape) -->
    <corners android:radius="50dp"/>

    <!-- Optional border -->
    <stroke
        android:width="1dp"
        android:color="#DADCE0"/>

    <!-- Inner spacing -->
    <padding
        android:left="12dp"
        android:top="4dp"
        android:right="12dp"
        android:bottom="4dp"/>
</shape>