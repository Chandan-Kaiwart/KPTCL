<?xml version="1.0" encoding="utf-8"?>
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">

    <!-- Default background -->
    <solid android:color="#E8F5E9"/> <!-- Light green -->

    <!-- Rounded pill shape -->
    <corners android:radius="50dp"/>

    <!-- Optional border -->
    <stroke
        android:width="1dp"
        android:color="#4CAF50"/>

    <!-- Padding -->
    <padding
        android:left="12dp"
        android:top="4dp"
        android:right="12dp"
        android:bottom="4dp"/>
</shape>